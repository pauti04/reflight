{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "reflight", "serve"],
      "port": 8724
    },
    {
      "name": "ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "ui"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "static-demo",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8931", "-d", "ui/out"],
      "port": 8931,
      "autoPort": false
    }
  ]
}
